<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"

    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Texto Sección -->
    <TextView
        android:id="@+id/txtSeccion"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:text="@string/app_seccion"
        android:textSize="16sp"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="40dp"
        android:layout_marginStart="16dp"/>

    <!-- Spinner Sección -->
    <Spinner
        android:id="@+id/spinseccion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:entries="@array/seccion"
        app:layout_constraintTop_toTopOf="@id/txtSeccion"
        app:layout_constraintBottom_toBottomOf="@id/txtSeccion"
        app:layout_constraintStart_toEndOf="@id/txtSeccion"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"/>

    <!-- Texto Asignatura -->
    <TextView
        android:id="@+id/txtArea"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:text="@string/app_area"
        android:textSize="16sp"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtSeccion"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="40dp"
        android:layout_marginStart="16dp"/>

    <!-- Spinner Asignatura -->
    <Spinner
        android:id="@+id/spinarea"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:entries="@array/asignaturas"
        app:layout_constraintTop_toTopOf="@id/txtArea"
        app:layout_constraintBottom_toBottomOf="@id/txtArea"
        app:layout_constraintStart_toEndOf="@id/txtArea"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp"/>

    <!-- EditText Tema -->
    <EditText
        android:id="@+id/editTextText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/app_tema"
        android:inputType="text"
        app:layout_constraintTop_toBottomOf="@id/spinarea"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="120dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"/>

    <!-- Botón Registrar -->


    <!-- Botón Ver Clases -->

    <Button
        android:id="@+id/btnregistrar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="204dp"
        android:text="@string/app_clase"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/editTextText" />

    <Button
        android:id="@+id/btnverclases"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="Ver Clases"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnregistrar" />

</androidx.constraintlayout.widget.ConstraintLayout>